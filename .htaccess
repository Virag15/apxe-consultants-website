# ============================================================
#  APXE CONSULTANTS, Apache configuration
#  (Only active on Apache hosting, ignored by Vercel/Netlify.)
# ============================================================

RewriteEngine On

# ------------------------------------------------------------
#  Force HTTPS
# ------------------------------------------------------------
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ------------------------------------------------------------
#  Remove trailing slash (except for actual directories)
# ------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [L,R=301]

# ------------------------------------------------------------
#  Redirect /anything.html to /anything (clean URLs)
# ------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# ------------------------------------------------------------
#  Internally serve /anything as /anything.html
# ------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ------------------------------------------------------------
#  Legacy URL redirects (old pages to new)
# ------------------------------------------------------------
Redirect 301 /insights /work
Redirect 301 /how-we-work /#approach
Redirect 301 /industries /services
Redirect 301 /index2 /
Redirect 301 /test /

# ------------------------------------------------------------
#  Custom 404
# ------------------------------------------------------------
ErrorDocument 404 /404.html

# ------------------------------------------------------------
#  Security headers
# ------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # Remove server signature
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# ------------------------------------------------------------
#  Caching, long for assets, short for HTML
# ------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 hour"
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|svg|png|jpg|jpeg|webp|woff2?|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

# ------------------------------------------------------------
#  Gzip / Brotli compression
# ------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ------------------------------------------------------------
#  Disable directory browsing
# ------------------------------------------------------------
Options -Indexes

# ------------------------------------------------------------
#  Prevent access to hidden and sensitive files
# ------------------------------------------------------------
<FilesMatch "^\.|\.(env|log|sql|bak|md|sh)$">
  Require all denied
</FilesMatch>
