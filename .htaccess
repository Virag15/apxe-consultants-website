# ============================================================
#  APXE CONSULTANTS — Apache/LiteSpeed config (Hostinger)
# ============================================================

Options +FollowSymLinks -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ----------------------------------------------------------
  #  Force HTTPS
  # ----------------------------------------------------------
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ----------------------------------------------------------
  #  Redirect /xyz.html to /xyz (clean URLs, SEO)
  # ----------------------------------------------------------
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]

  # ----------------------------------------------------------
  #  Remove trailing slash for non-directory URLs
  # ----------------------------------------------------------
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^ %1 [L,R=301]

  # ----------------------------------------------------------
  #  Internally rewrite /xyz to /xyz.html
  # ----------------------------------------------------------
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  # ----------------------------------------------------------
  #  Legacy URL redirects
  # ----------------------------------------------------------
  RewriteRule ^insights/?$ /work [R=301,L]
  RewriteRule ^insights/(.+)$ /work/$1 [R=301,L]
  RewriteRule ^how-we-work/?$ /#approach [R=301,L]
  RewriteRule ^industries/?$ /services [R=301,L]
  RewriteRule ^index2/?$ / [R=301,L]
  RewriteRule ^test/?$ / [R=301,L]
</IfModule>

# ============================================================
#  Security headers
# ============================================================
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# ============================================================
#  Caching
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 hour"
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|svg|png|jpg|jpeg|webp|woff2?|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================================
#  Gzip / Brotli compression
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ============================================================
#  Disable directory browsing & block sensitive files
# ============================================================
Options -Indexes

<FilesMatch "^\.">
  Require all denied
</FilesMatch>

<FilesMatch "\.(env|log|sql|bak|md|sh|ini|conf)$">
  Require all denied
</FilesMatch>

ErrorDocument 404 /404.html
